  "keyFeatures": [
    "Synchronized lyrics playback with beat, chord, and chorus data from Songle",
    "Hierarchical text units (phrase → word → character) with per-character timing",
    "Custom Timer support for plugging in different audio backends",
    "Host integration for embedding lyric apps inside the TextAlive platform",
    "Easing functions and 2D matrix utilities for smooth lyric animations",
    "Vocal amplitude and valence/arousal data for expressive visualizations",
    "Font loading support including Google Fonts and Morisawa TypeSquare",
    "Works via CDN script tag or npm package"
  ],
